# ElevenLabs (agents, telephony, transcripts/recordings)
ELEVENLABS_API_KEY=
ELEVENLABS_ESTIMATOR_AGENT_ID=
ELEVENLABS_CALLER_AGENT_ID=
ELEVENLABS_CLOSER_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=

# Twilio (real PSTN calls, imported into the ElevenLabs dashboard)
TWILIO_ACCOUNT_SID=
TWILIO_CLIENT_SECRET=
TWILIO_PHONE_NUMBER=

# OpenAI (document-PDF extraction, report narrative, agents' underlying LLM)
OPENAI_API_KEY=

# Tavily (P1 business-discovery provider, see app/services/discovery.py)
TAVILY_API_KEY=

# Backend
# Defaults to a local SQLite file if unset -- fine for dev/hackathon build,
# swap for a Supabase Postgres connection string once Lovable provisions one.
DATABASE_URL=
WEBHOOK_BASE_URL=http://localhost:8000
WEBHOOK_HMAC_SECRET=
